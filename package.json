{
  "name": "ua-info",
  "version": "1.2.0",
  "description": "Split user agent string into browser, application, runtime browser, OS, device type and device model",
  "author": "Chatchawan Koedsawas",
  "license": "MIT",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./v2": {
      "types": "./dist/esm/v2/index.d.ts",
      "import": "./dist/esm/v2/index.js",
      "require": "./dist/cjs/v2/index.js",
      "default": "./dist/esm/v2/index.js"
    },
    "./server": {
      "types": "./dist/esm/v2/server.d.ts",
      "import": "./dist/esm/v2/server.js",
      "require": "./dist/cjs/v2/server.js",
      "default": "./dist/esm/v2/server.js"
    },
    "./browser": {
      "types": "./dist/esm/v2/browser.d.ts",
      "import": "./dist/esm/v2/browser.js",
      "require": "./dist/cjs/v2/browser.js",
      "default": "./dist/esm/v2/browser.js"
    },
    "./v2/server": {
      "types": "./dist/esm/v2/server.d.ts",
      "import": "./dist/esm/v2/server.js",
      "require": "./dist/cjs/v2/server.js",
      "default": "./dist/esm/v2/server.js"
    },
    "./v2/browser": {
      "types": "./dist/esm/v2/browser.d.ts",
      "import": "./dist/esm/v2/browser.js",
      "require": "./dist/cjs/v2/browser.js",
      "default": "./dist/esm/v2/browser.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "lint": "eslint './src/**/*.ts'",
    "clean": "rm -rf dist",
    "build:esm": "tsc --project tsconfig.build.json",
    "build:cjs": "tsc --project tsconfig.build.cjs.json",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && node scripts/finalize-build.mjs",
    "test": "jest --verbose",
    "consumer:check": "node scripts/verify-consumers.mjs",
    "check": "npm run lint && npm test && npm run build && npm run pack:check",
    "pack:check": "node scripts/verify-package.mjs && npm run consumer:check",
    "prepack": "npm run check"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "javascript",
    "utils",
    "utilities"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^8.25.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^4.9.5"
  }
}
